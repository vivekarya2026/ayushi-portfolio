# Supabase - get these from your project's Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# Server-only. Never expose to the client. Used by the migration script and admin tasks.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Public base URL of the CMS (admin + /api/contact)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
REVALIDATE_SECRET=dev-secret

# Contact form → email (Resend: https://resend.com/api-keys)
RESEND_API_KEY=re_xxxxxxxx
ADMIN_EMAIL=you@example.com
# Until you verify a custom domain in Resend, use their onboarding sender:
CONTACT_FROM_EMAIL=Portfolio Contact <onboarding@resend.dev>
# Comma-separated origins allowed to POST to /api/contact (your static site)
CONTACT_ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080
# Optional override for the form action written by build:site
# CONTACT_API_URL=https://your-cms.vercel.app/api/contact

# --- Auto-rebuild the public site after CMS publish/edit ---
# Option A (preferred if Git is linked on the site Vercel project):
# SITE_DEPLOY_HOOK_URL=https://api.vercel.com/v1/integrations/deploy/prj_xxx/xxx
#
# Option B (used in this repo): GitHub PAT with repo scope → repository_dispatch
# triggers .github/workflows/rebuild-site.yml → vercel deploy --prod
# GITHUB_REBUILD_TOKEN=ghp_xxxxxxxx
# GITHUB_REBUILD_REPO=your-user/your-repo

